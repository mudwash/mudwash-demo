rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is an admin.
    // Guard: request.auth != null MUST come first — the get() call throws a
    // permissions error when auth is null, causing cascading "insufficient
    // permissions" errors on every collection that uses isAdmin().
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Garages: Public read, Admin write
    match /garages/{garageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Parts: Public read, Admin write
    match /parts/{partId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Services, Categories & Addons: Public read, Admin write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /addons/{addonId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /vehicleTypes/{typeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings: Public read, Admin write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Schedule: Public read, Admin write
    match /schedule/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bookings: Admin can do anything, Users can read/write their own
    match /bookings/{bookingId} {
      allow read: if true; // Allowed for slot availability checking
      allow create: if true; // Allow guest bookings for testing and ease of use
      allow update, delete: if isAdmin();
    }

    // Active Selections: Public read & write for live click tracking
    match /active_selections/{selectionId} {
      allow read: if true;
      allow write: if true;
    }

    // Ad Tracking: Any visitor can create/update their own session (write = public),
    // only admins can read/list sessions for the dashboard.
    match /adTracking/{sessionId} {
      allow create: if true;
      allow update: if true;
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }

    // Promocodes: Public read, Admin write
    match /promocodes/{code} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users: Users can read/write their own profiles, Admin can read all
    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow create: if request.auth != null && request.auth.uid == userId && request.resource.data.role == 'user';
      allow update: if (
        request.auth != null && 
        request.auth.uid == userId && 
        request.resource.data.role == resource.data.role
      ) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
